# ===== CABINET SAMI BELHARETH — .gitignore =====

# Données médicales sensibles (ne JAMAIS commiter)
*.patient
*.dicom
**/private/
**/secrets/
**/.env
**/.env.*
!**/.env.example

# Node.js (pour la phase de développement)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Next.js (pour la phase de développement)
.next/
out/
build/
dist/

# Supabase / DB
**/*.db
**/*.sqlite
**/*.sqlite3
supabase/.temp/

# Logs
logs/
*.log

# IDE / Éditeurs
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini
~$*
~WRL*.tmp
*.tmp

# Tests
coverage/
.nyc_output/

# Misc
*.bak
*.backup
